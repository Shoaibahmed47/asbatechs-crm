{
    "name": "@asbatechs-crm/database",
    "version": "0.1.0",
    "private": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "drizzle:generate": "drizzle-kit generate",
        "drizzle:migrate": "drizzle-kit migrate",
        "drizzle:push": "drizzle-kit push:pg",
        "db:seed": "npm run build && node dist/seed.js",
        "db:reset": "npm run build && node dist/reset.js",
        "db:cleanup-invalid-departments": "npm run build && node dist/cleanup-invalid-departments.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "next": "^16.2.4",
        "pg": "^8.12.0"
    },
    "devDependencies": {
        "dotenv-cli": "^11.0.0",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "typescript": "^5.6.3"
    }
}
