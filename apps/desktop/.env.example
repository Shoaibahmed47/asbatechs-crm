# Optional code signing for Windows production builds
# CSC_LINK=path/to/certificate.pfx
# CSC_KEY_PASSWORD=your-password

# Generic update feed for electron-updater (production)
# DESKTOP_UPDATE_URL=https://downloads.example.com/asbatechs-crm/desktop

# CRM URL loaded by the desktop shell (development override)
# CRM_APP_URL=http://localhost:3000

# For production installer builds, copy crm-app.url.example → crm-app.url
# and set your live CRM origin on one line (https://...).
